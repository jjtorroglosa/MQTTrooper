<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.jjtorroglosa.mqttrooper</string>
    <key>ProgramArguments</key>
    <array>
            <string>{{ .ExecutablePath }}</string>
        <string>-c</string>
            <string>{{ .ConfigPath }}</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>{{ .Home }}/bin:/usr/local/bin:/usr/local/sbin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
      <key>SuccessfulExit</key>
      <false/>
      <key>Crashed</key>
      <true/>
    </dict>
    <key>StandardOutPath</key>
        <string>{{ .LogfilePath }}</string>
    <key>StandardErrorPath</key>
        <string>{{ .ErrLogfilePath }}</string>
    <key>ProcessType</key>
    <string>Interactive</string>
    <key>Nice</key>
    <integer>-20</integer>
    <key>WatchPaths</key>
    <array>
            <string>{{ .ConfigPath }}</string>
    </array>
</dict>
</plist>
